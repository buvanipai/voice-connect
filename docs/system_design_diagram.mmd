%%{init: {'theme': 'base', 'themeVariables': { 'background': '#ffffff'}}}%%
flowchart LR
    %% GLOBAL STYLES
    linkStyle default stroke:#000000,stroke-width:2px;

    subgraph Customer["CUSTOMER LAYER"]
        direction TB
        Phone[Customer Calls<br/>Business Number]
        Mobile[Mobile Landing<br/>Page View]
    end

    %% TOP TIER: VOICE PROCESSING
    subgraph Forward["CALL FORWARDING"]
        direction TB
        BizNum[Business<br/>Number]
        CloudNum[VoiceConnect<br/>Cloud Number<br/>AWS]
    end
    
    subgraph Telephony["TELEPHONY"]
        direction TB
        Twilio[Twilio Voice<br/>& SMS]
    end
    
    subgraph AI_Core["AI PROCESSING"]
        direction TB
        STT[Deepgram STT]
        Intent[Claude Haiku<br/>Intent & Routing]
        TTS[Azure TTS]
    end

    %% BOTTOM TIER: DATA & MANAGEMENT
    subgraph Content["CONTENT SYSTEM"]
        direction TB
        Landing[Mobile Landing<br/>Page Generator]
        Voicemail[Voicemail<br/>Transcription]
    end
    
    subgraph Storage["DATABASE"]
        direction TB
        KB[Knowledge Base<br/>Chroma]
        DB[(PostgreSQL)]
    end
    
    subgraph Staff["STAFF TOOLS"]
        direction TB
        Dashboard[Web Dashboard<br/>Greetings/Settings]
        Email[Email Routing<br/>Extensions]
    end

    %% --- THE CLEAN FLOW (Top Tier) ---
    Phone --> BizNum
    BizNum -.-> CloudNum
    CloudNum --> Twilio
    Twilio --> STT
    STT --> Intent
    Intent --> TTS
    TTS --> Twilio
    Twilio --> Phone

    %% --- THE CLEAN FLOW (Bottom Tier / Outputs) ---
    Intent -. create .-> Landing
    Landing --> Mobile
    Twilio -. SMS .-> Phone
    
    Intent -. transcript .-> Voicemail
    Voicemail --> Email
    
    %% Management Connections
    Dashboard -. manage .-> KB
    Dashboard -. update .-> DB
    
    %% Logs (Pointing down to avoid cluttering the voice line)
    Twilio --- DB
    Intent --- DB
    Intent --- KB

    %% --- STYLING (Standard Bhuvi IT Colors) ---
    style Customer fill:#E3F2FD,stroke:#1976D2,stroke-width:3px,color:#000
    style Forward fill:#FFF9C4,stroke:#F9A825,stroke-width:3px,color:#000
    style Telephony fill:#FFF3E0,stroke:#F57C00,stroke-width:3px,color:#000
    style AI_Core fill:#E8F5E9,stroke:#388E3C,stroke-width:3px,color:#000
    style Content fill:#F3E5F5,stroke:#7B1FA2,stroke-width:3px,color:#000
    style Storage fill:#FCE4EC,stroke:#C2185B,stroke-width:3px,color:#000
    style Staff fill:#E0F2F1,stroke:#00897B,stroke-width:3px,color:#000

    style Phone fill:#BBDEFB,stroke:#1976D2,stroke-width:2px,color:#000
    style Mobile fill:#BBDEFB,stroke:#1976D2,stroke-width:2px,color:#000
    style BizNum fill:#FFFDE7,stroke:#F9A825,stroke-width:2px,color:#000
    style Twilio fill:#FFE0B2,stroke:#F57C00,stroke-width:2px,color:#000
    style Intent fill:#C8E6C9,stroke:#388E3C,stroke-width:2px,color:#000
    style DB fill:#F8BBD0,stroke:#C2185B,stroke-width:2px,color:#000
    style Dashboard fill:#B2DFDB,stroke:#00897B,stroke-width:2px,color:#000